{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "USB Fixer",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": { "all": false },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "bundle": {
      "active": true,
      "icon": ["icons/icon.ico"],
      "identifier": "com.angelvirion.usbfixer",
      "resources": ["HPUSBDisk.exe"],
      "targets": ["app"],
      "copyright": "© 2024 Angel Virion - MIT License",
      "windows": {
        "wix": null,
        "nsis": null
      }
    },
    "windows": [{
      "title": "USB Fixer",
      "width": 450,
      "height": 500,
      "resizable": false,
      "center": true
    }],
    "systemTray": null
  }
}
