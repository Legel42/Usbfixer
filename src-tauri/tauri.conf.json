{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "USB Fixer",
  "version": "1.0.0",
  "identifier": "com.angelvirion.usbfixer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "USB Fixer",
        "width": 450,
        "height": 500,
        "resizable": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "resources": ["HPUSBDisk.exe"],
    "targets": ["app"],
    "copyright": "© 2025 Angel Virion - MIT License",
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}
